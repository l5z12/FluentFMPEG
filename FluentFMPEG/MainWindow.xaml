<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="FluentFMPEG.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FluentFMPEG"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="FluentFMPEG">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              x:Name="AppTitleBar"
              Height="48">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" MinWidth="148" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       x:Name="AppTitleText"
                       Text="FluentFMPEG"
                       VerticalAlignment="Center"
                       Margin="16,0,0,0"
                       Style="{StaticResource CaptionTextBlockStyle}" />
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="0,0,4,0">
                <Button x:Name="SettingsButton"
                        Click="OnSettingsClick"
                        Background="Transparent"
                        BorderThickness="0"
                        Width="40"
                        Height="32"
                        Padding="0"
                        ToolTipService.ToolTip="Settings">
                    <FontIcon Glyph="&#xE713;" FontSize="16" />
                </Button>
                <Button x:Name="AboutButton"
                        Click="OnAboutClick"
                        Background="Transparent"
                        BorderThickness="0"
                        Width="40"
                        Height="32"
                        Padding="0"
                        ToolTipService.ToolTip="About">
                    <FontIcon Glyph="&#xE946;" FontSize="16" />
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1"
              Padding="24,8,24,24"
              RowSpacing="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Spacing="8">
                <TextBlock Text="Mode" VerticalAlignment="Center" Opacity="0.8" />
                <ComboBox x:Name="ModeCombo"
                          MinWidth="180"
                          SelectionChanged="OnModeChanged">
                    <ComboBoxItem Content="Convert" Tag="Convert" />
                    <ComboBoxItem Content="Extract audio from video" Tag="ExtractAudio" />
                    <ComboBoxItem Content="Extract video (no audio)" Tag="ExtractVideo" />
                    <ComboBoxItem Content="Mix video + audio" Tag="Mix" />
                </ComboBox>
                <TextBlock Text="Quality" Margin="20,0,0,0" VerticalAlignment="Center" Opacity="0.8" />
                <ComboBox x:Name="QualityCombo"
                          MinWidth="140"
                          SelectionChanged="OnQualityChanged">
                    <ComboBoxItem Content="Smaller" Tag="Low" />
                    <ComboBoxItem Content="Balanced" Tag="Medium" />
                    <ComboBoxItem Content="Higher" Tag="High" />
                </ComboBox>
            </StackPanel>

            <Border Grid.Row="1"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    AllowDrop="True"
                    DragOver="OnDragOver"
                    Drop="OnDropPrimary">
                <Grid ColumnSpacing="12" RowSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               x:Name="PrimaryLabel"
                               Text="Input file"
                               FontWeight="SemiBold" />
                    <TextBlock Grid.Row="1" Grid.Column="0"
                               x:Name="InputPathText"
                               Text="Drop a file here or click Browse…"
                               TextTrimming="CharacterEllipsis"
                               Opacity="0.8" />
                    <TextBlock Grid.Row="2" Grid.Column="0"
                               x:Name="DetectionText"
                               Text=""
                               Opacity="0.6"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis" />
                    <Button Grid.Row="0" Grid.RowSpan="3" Grid.Column="1"
                            x:Name="BrowseButton"
                            Content="Browse…"
                            VerticalAlignment="Center"
                            Click="OnBrowsePrimaryClick" />
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    x:Name="SecondaryInputBorder"
                    Visibility="Collapsed"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    AllowDrop="True"
                    DragOver="OnDragOver"
                    Drop="OnDropSecondary">
                <Grid ColumnSpacing="12" RowSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="Audio file"
                               FontWeight="SemiBold" />
                    <TextBlock Grid.Row="1" Grid.Column="0"
                               x:Name="SecondaryPathText"
                               Text="Drop an audio file here or click Browse…"
                               TextTrimming="CharacterEllipsis"
                               Opacity="0.8" />
                    <TextBlock Grid.Row="2" Grid.Column="0"
                               x:Name="SecondaryDetectionText"
                               Text=""
                               Opacity="0.6"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis" />
                    <Button Grid.Row="0" Grid.RowSpan="3" Grid.Column="1"
                            Content="Browse…"
                            VerticalAlignment="Center"
                            Click="OnBrowseSecondaryClick" />
                </Grid>
            </Border>

            <Border Grid.Row="3"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20"
                    Background="{ThemeResource LayerFillColorDefaultBrush}">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="200" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Output" VerticalAlignment="Center" />
                    <TextBox Grid.Column="1"
                             x:Name="OutputPathBox"
                             PlaceholderText="Output path will appear here once a file is selected" />
                    <Button Grid.Column="2"
                            x:Name="SaveAsButton"
                            Content="Save as…"
                            Click="OnSaveAsClick"
                            IsEnabled="False" />
                    <ComboBox Grid.Column="3"
                              x:Name="FormatCombo"
                              SelectionChanged="OnFormatChanged"
                              IsEnabled="False"
                              HorizontalAlignment="Stretch" />
                </Grid>
            </Border>

            <Expander Grid.Row="4"
                      x:Name="AdvancedExpander"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch"
                      Header="Advanced settings">
                <Grid ColumnSpacing="12" RowSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="Resolution" VerticalAlignment="Center" />
                    <ComboBox Grid.Row="0" Grid.Column="1"
                              x:Name="ResolutionCombo"
                              IsEditable="True"
                              HorizontalAlignment="Stretch"
                              PlaceholderText="Keep">
                        <ComboBoxItem Content="Keep" />
                        <ComboBoxItem Content="3840x2160" />
                        <ComboBoxItem Content="2560x1440" />
                        <ComboBoxItem Content="1920x1080" />
                        <ComboBoxItem Content="1280x720" />
                        <ComboBoxItem Content="854x480" />
                        <ComboBoxItem Content="640x360" />
                    </ComboBox>

                    <TextBlock Grid.Row="0" Grid.Column="2"
                               Text="Frame rate" VerticalAlignment="Center" />
                    <ComboBox Grid.Row="0" Grid.Column="3"
                              x:Name="FpsCombo"
                              IsEditable="True"
                              HorizontalAlignment="Stretch"
                              PlaceholderText="Keep">
                        <ComboBoxItem Content="Keep" />
                        <ComboBoxItem Content="24" />
                        <ComboBoxItem Content="25" />
                        <ComboBoxItem Content="30" />
                        <ComboBoxItem Content="50" />
                        <ComboBoxItem Content="60" />
                    </ComboBox>

                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="Sample rate" VerticalAlignment="Center" />
                    <ComboBox Grid.Row="1" Grid.Column="1"
                              x:Name="SampleRateCombo"
                              IsEditable="True"
                              HorizontalAlignment="Stretch"
                              PlaceholderText="Keep">
                        <ComboBoxItem Content="Keep" />
                        <ComboBoxItem Content="22050" />
                        <ComboBoxItem Content="32000" />
                        <ComboBoxItem Content="44100" />
                        <ComboBoxItem Content="48000" />
                    </ComboBox>

                    <TextBlock Grid.Row="1" Grid.Column="2"
                               Text="Channels" VerticalAlignment="Center" />
                    <ComboBox Grid.Row="1" Grid.Column="3"
                              x:Name="ChannelsCombo"
                              HorizontalAlignment="Stretch"
                              SelectedIndex="0">
                        <ComboBoxItem Content="Keep" Tag="0" />
                        <ComboBoxItem Content="Mono" Tag="1" />
                        <ComboBoxItem Content="Stereo" Tag="2" />
                    </ComboBox>

                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="Audio bitrate" VerticalAlignment="Center" />
                    <ComboBox Grid.Row="2" Grid.Column="1"
                              x:Name="AudioBitrateCombo"
                              IsEditable="True"
                              HorizontalAlignment="Stretch"
                              PlaceholderText="Use Quality setting">
                        <ComboBoxItem Content="Use Quality setting" />
                        <ComboBoxItem Content="96k" />
                        <ComboBoxItem Content="128k" />
                        <ComboBoxItem Content="192k" />
                        <ComboBoxItem Content="256k" />
                        <ComboBoxItem Content="320k" />
                    </ComboBox>

                    <TextBlock Grid.Row="3" Grid.Column="0"
                               Text="Trim start" VerticalAlignment="Center" />
                    <TextBox Grid.Row="3" Grid.Column="1"
                             x:Name="TrimStartBox"
                             PlaceholderText="hh:mm:ss or seconds" />
                    <TextBlock Grid.Row="3" Grid.Column="2"
                               Text="Trim end" VerticalAlignment="Center" />
                    <TextBox Grid.Row="3" Grid.Column="3"
                             x:Name="TrimEndBox"
                             PlaceholderText="hh:mm:ss or seconds" />

                    <TextBlock Grid.Row="4" Grid.Column="0"
                               Text="Hardware" VerticalAlignment="Center" />
                    <ComboBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3"
                              x:Name="HardwareEncoderCombo"
                              HorizontalAlignment="Stretch"
                              SelectedIndex="0"
                              ToolTipService.ToolTip="Used for H.264 / H.265 video encoding. Other codecs always run on CPU." />
                </Grid>
            </Expander>

            <Border Grid.Row="5"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Background="{ThemeResource LayerFillColorDefaultBrush}">
                <ScrollViewer>
                    <TextBlock x:Name="LogText"
                               Padding="16"
                               FontFamily="Consolas"
                               FontSize="12"
                               TextWrapping="Wrap"
                               IsTextSelectionEnabled="True" />
                </ScrollViewer>
            </Border>

            <Grid Grid.Row="6" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ProgressBar Grid.Column="0"
                             x:Name="Progress"
                             Minimum="0" Maximum="100"
                             VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           x:Name="ProgressText"
                           Text="Ready"
                           VerticalAlignment="Center"
                           MinWidth="120"
                           TextAlignment="Right" />
            </Grid>

            <StackPanel Grid.Row="7"
                        Orientation="Horizontal"
                        Spacing="12"
                        HorizontalAlignment="Right">
                <Button x:Name="CancelButton"
                        Content="Cancel"
                        IsEnabled="False"
                        Click="OnCancelClick" />
                <Button x:Name="ConvertButton"
                        Content="Convert"
                        Style="{ThemeResource AccentButtonStyle}"
                        IsEnabled="False"
                        Click="OnConvertClick" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
